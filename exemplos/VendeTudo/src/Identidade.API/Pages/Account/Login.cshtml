@page
@model VendeTudo.Identidade.API.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Login";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h4>Login - VendeTudo</h4>
                </div>
                <div class="card-body">
                    <form method="post">
                        <input type="hidden" asp-for="ReturnUrl" />
                        
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        
                        <div class="mb-3">
                            <label asp-for="Input.Email" class="form-label"></label>
                            <input asp-for="Input.Email" class="form-control" />
                            <span asp-validation-for="Input.Email" class="text-danger"></span>
                        </div>
                        
                        <div class="mb-3">
                            <label asp-for="Input.Senha" class="form-label"></label>
                            <input asp-for="Input.Senha" class="form-control" />
                            <span asp-validation-for="Input.Senha" class="text-danger"></span>
                        </div>
                        
                        <div class="mb-3 form-check">
                            <input asp-for="Input.LembrarMe" class="form-check-input" />
                            <label asp-for="Input.LembrarMe" class="form-check-label"></label>
                        </div>
                        
                        <button type="submit" class="btn btn-primary w-100">Entrar</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
